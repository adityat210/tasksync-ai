{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "aws-lambda"]
  },
  "include": ["functions/**/*.ts", "shared/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}

